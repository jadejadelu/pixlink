# PixLink Git Ignore Files

# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建输出
dist/
build/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local

# Docker Compose本地配置文件（包含SMTP密码等敏感信息）
docker-compose-local.yml

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db

# 日志文件
*.log
logs/

# 测试覆盖率
coverage/
.nyc_output/

# 临时文件
tmp/
temp/

# Docker相关
.dockerignore

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 证书文件（不提交密钥）
*.key
*.pem
!ca.crt

# 浏览器记录（HAR文件）
浏览器记录*.har
*.har

# ZTM演示环境数据
pixlink-demo-ztm/*/agent-data/
pixlink-demo-ztm/*/data/
pixlink-demo-ztm/*/hub-data/
pixlink-demo-ztm/*/client*-agent-data/
pixlink-demo-ztm/*/meshes/
pixlink-demo-ztm/*/fs/
pixlink-demo-ztm/*.db
pixlink-demo-ztm/*.sqlite
pixlink-demo-ztm/*.sqlite3

# ZTM Agent数据（包含Identity和Permit等敏感信息）
*agent-data/
*data/
*hub-data/
*meshes/
